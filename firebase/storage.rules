rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Vehicle images: public read
    match /vehicles/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Customer documents: admin only
    match /customers/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Invoices: admin only
    match /invoices/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
