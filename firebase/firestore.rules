rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only authenticated admin users can read/write everything
    // Public read is allowed only for vehicles with showOnLanding=true (handled in backend)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Vehicles: allow public read for landing page
    match /vehicles/{vehicleId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
