{
  "functions": [
    {
      "source": "../backend",
      "codebase": "backend",
      "ignore": [
        "node_modules",
        ".git",
        "src",
        "*.ts",
        ".env*",
        "firebase-debug.log"
      ],
      "predeploy": ["npm --prefix $RESOURCE_DIR run build"]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "../frontend/out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/**", "function": "api" },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
